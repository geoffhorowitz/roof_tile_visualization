# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional (for custom backend storage manipulations if bypassing RLS)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Local AI Server Configuration
COMFYUI_URL=http://127.0.0.1:8188

# Vertex AI Production Configuration
# Set to 'true' to route generation requests to Google Cloud Vertex AI instead of ComfyUI.
VERTEX_USE_ENDPOINT=false
# The Google Cloud Project ID hosting the Vertex AI endpoint.
VERTEX_PROJECT_ID=your_gcp_project_id
# The GCP region/location where the Vertex AI endpoint is deployed (e.g., us-central1).
VERTEX_LOCATION=us-central1
# The numeric Endpoint ID of the Vertex AI Custom Prediction Endpoint.
VERTEX_ENDPOINT_ID=your_vertex_endpoint_id
# Local Development Only: The JSON string of the GCP Service Account Key that has 'Vertex AI User' permissions.
# Leave blank when deployed to Cloud Run (it will use the Cloud Run environment service credentials automatically).
VERTEX_SERVICE_ACCOUNT_KEY=

